@model List<MVCShopping1.Models.OrderDetail>
@{
    ViewData["Title"] = "Chi Tiết Đơn Hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Chi Tiết Đơn Hàng <span style="color:#c97b8a">#@ViewBag.OrderID</span></h2>
    <a asp-action="MyOrders" class="btn btn-outline-secondary">
        ← Quay lại
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Sản phẩm</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Product?.ModelName</td>
                        <td>$@item.UnitCost.ToString("N2")</td>
                        <td>@item.Quantity</td>
                        <td class="fw-bold">
                            $@((item.UnitCost * item.Quantity).ToString("N2"))
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-warning">
                    <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                    <td class="fw-bold text-danger fs-5">
                        $@ViewBag.Total.ToString("N2")
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<div class="mt-4">
    <a asp-controller="Products" asp-action="Search" class="btn btn-primary">
        🛍️ Tiếp tục mua sắm
    </a>
</div>