@model List<MVCShopping1.Models.ShoppingCartItem>
@{
    ViewData["Title"] = "Thanh Toán";
}

<h2 class="mb-4">💳 Xác Nhận Đơn Hàng</h2>

<div class="card shadow-sm mb-4">
    <div class="card-header" style="background:#c97b8a;color:white">
        <h5 class="mb-0">📋 Chi tiết đơn hàng</h5>
    </div>
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Sản phẩm</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td>$@item.Price</td>
                        <td>@item.Quantity</td>
                        <td class="fw-bold">$@(item.Price* item.Quantity)</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-warning">
                    <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                    <td class="fw-bold text-danger fs-5">
                        $@Model.Sum(i => i.Price * i.Quantity)
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<form asp-action="Confirm" method="post">
    <div class="d-flex gap-3">
        <button type="submit" class="btn btn-success btn-lg px-5">
            ✅ Xác nhận đặt hàng
        </button>
        <a asp-controller="ShoppingCart" asp-action="Index"
           class="btn btn-outline-secondary btn-lg">
            ← Quay lại giỏ
        </a>
    </div>
</form>