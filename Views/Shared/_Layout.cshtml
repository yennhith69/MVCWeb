<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MVCShopping</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Màu hồng dịu nhẹ */
        body {
            background-color: #fff5f7;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .navbar {
            background-color: #c97b8a !important;
            box-shadow: 0 2px 6px rgba(0,0,0,0.15);
        }
        .navbar-brand {
            color: #fff !important;
            font-weight: 700;
            font-size: 1.3rem;
        }
        .nav-link {
            color: #ffe0e6 !important;
            transition: color 0.2s;
        }
        .nav-link:hover {
            color: #ffffff !important;
        }
        .footer {
            background-color: #c97b8a;
            color: #ffe0e6;
            padding: 16px 0;
            margin-top: 40px;
        }
        .footer a { color: #fff; text-decoration: none; }
        .btn-primary {
            background-color: #d4849a;
            border-color: #d4849a;
        }
        .btn-primary:hover {
            background-color: #b8697e;
            border-color: #b8697e;
        }
        .btn-success {
            background-color: #6aab7d;
            border-color: #6aab7d;
        }
        .table thead.table-dark th {
            background-color: #c97b8a;
            border-color: #b8697e;
        }
        .container { padding-top: 20px; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    🛒 MVCShopping
                </a>
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Customers" asp-action="Index">Customers</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Login" asp-action="Index">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Products" asp-action="Search">Search Product</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Checkout" asp-action="MyOrders">My Orders</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Admin" asp-action="Login">Admin</a>
                        </li>
                    </ul>
                    @{
                        var currentUser = Context.Session.GetString("UserName");
                    }
                    @if (currentUser != null)
                    {
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <span class="nav-link">👤 @currentUser</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Login" asp-action="Logout">Logout</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container text-center">
            &copy; 2026 - MVCShopping
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>