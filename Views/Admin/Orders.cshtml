@model List<MVCShopping1.Models.Order>
@{
    ViewData["Title"] = "Quản Lý Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📋 Quản Lý Đơn Hàng</h2>
    <div class="d-flex gap-2">
        <a asp-action="Statistics" class="btn btn-success">📊 Thống kê</a>
        <a asp-action="EmployeeList" class="btn btn-info text-white">👥 Nhân viên</a>
        <a asp-action="Logout" class="btn btn-outline-danger">Logout</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Order ID</th>
                    <th>Khách hàng</th>
                    <th>Nhân viên</th>
                    <th>Ngày đặt</th>
                    <th>Ngày giao</th>
                    <th style="width:150px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td><strong>#@order.OrderID</strong></td>
                        <td>@order.Customer?.FullName</td>
                        <td>
                            @if (order.Employee != null)
                            {
                                <span class="badge bg-info">@order.Employee.FullName</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Chưa gán</span>
                            }
                        </td>
                        <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@order.ShipDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a asp-action="OrderDetails"
                               asp-route-orderId="@order.OrderID"
                               class="btn btn-primary btn-sm">Chi tiết</a>
                            <a asp-action="EditOrder"
                               asp-route-orderId="@order.OrderID"
                               class="btn btn-warning btn-sm">Sửa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>