@model MVCShopping1.Models.Employee
@{
    ViewData["Title"] = "Thêm Nhân Viên";
}

<h2 class="mb-4">➕ Thêm Nhân Viên Mới</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="CreateEmployee" method="post">
            <div class="mb-3">
                <label class="form-label fw-bold">Họ tên</label>
                <input asp-for="FullName" class="form-control"
                       placeholder="Nhập họ tên..." />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Email</label>
                <input asp-for="Email" class="form-control"
                       placeholder="Nhập email..." />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Điện thoại</label>
                <input asp-for="Phone" class="form-control"
                       placeholder="Nhập số điện thoại..." />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">💾 Lưu</button>
                <a asp-action="EmployeeList" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>