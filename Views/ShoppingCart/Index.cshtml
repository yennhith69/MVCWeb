@model List<MVCShopping1.Models.ShoppingCartItem>
@{
    ViewData["Title"] = "Giỏ Hàng";
}

<h2 class="mb-4">🛒 Giỏ Hàng Của Bạn</h2>

@if (Model != null && Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Đơn giá</th>
                        <th style="width:200px">Số lượng</th>
                        <th>Thành tiền</th>
                        <th style="width:80px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">
                                <strong>@item.ProductName</strong>
                            </td>
                            <td class="align-middle text-danger">
                                $@item.Price
                            </td>
                            <td class="align-middle">
                                <form asp-action="Update" asp-controller="ShoppingCart"
                                      method="post" class="d-flex gap-1">
                                    <input type="hidden" name="productId"
                                           value="@item.ProductID" />
                                    <input type="number" name="quantity"
                                           value="@item.Quantity" min="1"
                                           class="form-control form-control-sm"
                                           style="width:65px" />
                                    <button type="submit"
                                            class="btn btn-warning btn-sm">
                                        Sửa
                                    </button>
                                </form>
                            </td>
                            <td class="align-middle fw-bold">
                                $@(item.Price* item.Quantity)
                            </td>
                            <td class="align-middle">
                                <form asp-action="Remove" asp-controller="ShoppingCart"
                                      method="post">
                                    <input type="hidden" name="productId"
                                           value="@item.ProductID" />
                                    <button type="submit"
                                            class="btn btn-danger btn-sm">
                                        ✕
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-light">
                        <td colspan="3" class="text-end fw-bold fs-5">Tổng cộng:</td>
                        <td class="fw-bold fs-5 text-danger">
                            $@Model.Sum(i => i.Price * i.Quantity)
                        </td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="d-flex gap-3 mt-4">
        <a asp-controller="Products" asp-action="Search"
           class="btn btn-outline-secondary btn-lg">
            ← Tiếp tục mua
        </a>
        <a asp-controller="Checkout" asp-action="Index"
           class="btn btn-success btn-lg">
            Thanh toán →
        </a>
    </div>
}
else
{
    <div class="text-center mt-5">
        <div style="font-size:4rem">🛒</div>
        <h4 class="mt-3 text-muted">Giỏ hàng trống!</h4>
        <a asp-controller="Products" asp-action="Search"
           class="btn btn-primary mt-3">Đi mua sắm ngay</a>
    </div>
}